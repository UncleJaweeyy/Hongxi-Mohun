rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        adminDoc().data.active == true;
    }

    function isValidUsername(value) {
      return value is string && value.matches('^[A-Za-z0-9]{4,20}$');
    }

    function isValidUsernameKey(value) {
      return value is string && value.matches('^[a-z0-9]{4,20}$');
    }

    function isValidPhone(value) {
      return value is string &&
        (value == '' || value.matches('^\\+?[0-9\\s-]{7,20}$'));
    }

    function hasValidUserProfileFields() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'username',
        'usernameLower',
        'email',
        'phone',
        'online',
        'lastOnlineAt',
        'updatedAt',
        'createdAt'
      ]) &&
      request.resource.data.keys().hasAll([
        'uid',
        'username',
        'usernameLower',
        'email',
        'phone',
        'online',
        'lastOnlineAt',
        'updatedAt',
        'createdAt'
      ]);
    }

    function hasValidUserProfileValues(uid) {
      return request.auth.uid == uid &&
        request.resource.data.uid == uid &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == request.auth.token.email &&
        request.auth.token.email_verified == true &&
        isValidUsername(request.resource.data.username) &&
        isValidUsernameKey(request.resource.data.usernameLower) &&
        request.resource.data.username.lower() == request.resource.data.usernameLower &&
        isValidPhone(request.resource.data.phone) &&
        request.resource.data.online is bool &&
        request.resource.data.lastOnlineAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.usernameLower)).data.uid == request.auth.uid &&
        getAfter(/databases/$(database)/documents/usernames/$(request.resource.data.usernameLower)).data.username == request.resource.data.username;
    }

    function isValidUserProfileCreate(uid) {
      return hasValidUserProfileFields() &&
        hasValidUserProfileValues(uid) &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.lastOnlineAt == request.time &&
        request.resource.data.createdAt == request.time;
    }

    function isValidUserProfileUpdate(uid) {
      return hasValidUserProfileFields() &&
        hasValidUserProfileValues(uid) &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.lastOnlineAt == request.time;
    }

    function isValidUsernameReservation(usernameKey) {
      return request.resource.data.keys().hasOnly([
        'uid',
        'username',
        'usernameLower',
        'createdAt'
      ]) &&
      request.resource.data.keys().hasAll([
        'uid',
        'username',
        'usernameLower',
        'createdAt'
      ]) &&
      request.resource.data.uid == request.auth.uid &&
        request.resource.data.usernameLower == usernameKey &&
        isValidUsername(request.resource.data.username) &&
        isValidUsernameKey(request.resource.data.usernameLower) &&
        request.resource.data.username.lower() == request.resource.data.usernameLower &&
        request.resource.data.createdAt == request.time;
    }

    function isValidOwnUsernameDelete(usernameKey) {
      return signedIn() &&
        resource.data.uid == request.auth.uid &&
        getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.usernameLower != usernameKey;
    }

    match /siteContent/rankings {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteContent/news {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow get: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create: if signedIn() && isValidUserProfileCreate(uid);
      allow update: if signedIn() && isValidUserProfileUpdate(uid);
      allow delete: if false;
    }

    match /usernames/{usernameKey} {
      allow get: if signedIn();
      allow list: if isAdmin();
      allow create: if signedIn() &&
        !exists(/databases/$(database)/documents/usernames/$(usernameKey)) &&
        isValidUsernameReservation(usernameKey);
      allow update: if false;
      allow delete: if isValidOwnUsernameDelete(usernameKey);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
