{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      ".github/**",
      ".git/**",
      ".vscode/**",
      ".firebase/**",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "node_modules/**",
      "dev-server.cjs",
      "ADMIN_SETUP.md",
      "firestore.rules",
      "firestore.indexes.json",
      "js/shared/firebase-config.example.js"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=0, must-revalidate"
          }
        ]
      }
    ]
  }
}
